.title {
    display: flex;
    align-items: center;
    gap: 10px;
} 


.navigation_bar {
    background-color: #2ecc71; /* green */
    padding: 15px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: Arial, sans-serif;
} 

.navigation_bar a {
    margin-left: 25px;
    text-decoration: none;
    color: white;
    font-size: 1rem;
    font-weight: 500;
}

.navigation_bar a:hover {
    text-decoration: underline;
}
