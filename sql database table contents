CREATE DATABASE DB; -- CREATES DATABASE AND NAMES DATABSE DB TO CALL--

CREATE TABLE users (
    user_id     INT AUTO_INCREMENT PRIMARY KEY,--USER ID FOR UNIQUE USERS--
    email       VARCHAR(255) NOT NULL UNIQUE,--EMAIL OF USER TO UTILISE TO SEND EMAILS TO USER--
    username    VARCHAR(100) NOT NULL UNIQUE,--UNIQUE USER USERNAME--
    password    VARCHAR(255) NOT NULL,--USER PASSWORD FOR AUTHENTICATION AND ENCRYPTION--
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP --DATE USER CREATED ACCOUNT
); 

CREATE TABLE products (
    product_id   INT AUTO_INCREMENT PRIMARY KEY,--UNIQUE PRODUCT ID TO CALL AND REGISTER--
    product_name VARCHAR(150) NOT NULL UNIQUE,--REGISTERED PRODUCT NAME--
    price        DECIMAL(10,2) NOT NULL,--PROSUCT PRICE--
    in_stock     INT NOT NULL DEFAULT 0,--HOW MANY IN STOCK CONSTANTLY CHANGED AND MONITORED PER RESTOCK
    created_at   TIMESTAMP DEFAULT CURRENT_TIMESTAMP --TIMESTAMP--
);
